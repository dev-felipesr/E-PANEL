@model ComplaintIndexViewModel
@{
    ViewData["Title"] = "Reclamações";
}

<div class="page-header page-header-highlight panel-card d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
    <div>
        <h1 class="h3 page-title">Reclamações da ETEC @Model.EtecNumber</h1>
        <p class="text-secondary mb-0">Vote para priorizar os temas mais urgentes.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary px-4">Nova reclamação</a>
</div>

@if (TempData["Warning"] is string warning)
{
    <div class="alert alert-warning">@warning</div>
}

@if (!Model.Complaints.Any())
{
    <div class="alert alert-light border">Ainda não há reclamações nessa ETEC.</div>
}
else
{
    foreach (var complaint in Model.Complaints)
    {
        <article class="card panel-card complaint-card mb-3">
            <div class="card-body">
                <div class="feed-item-layout d-flex gap-3">
                    <div class="vote-controls text-center" data-url="@Url.Action("Vote", "Complaints")" data-id="@complaint.Id">
                        <button type="button" class="btn btn-sm vote-btn @(complaint.CurrentUserVote == 1 ? "btn-success" : "btn-outline-success")" data-value="1">▲</button>
                        <div class="fw-semibold score-value">@complaint.Score</div>
                        <button type="button" class="btn btn-sm vote-btn @(complaint.CurrentUserVote == -1 ? "btn-danger" : "btn-outline-danger")" data-value="-1">▼</button>
                    </div>
                    <div class="flex-grow-1 feed-content">
                        <h2 class="h5 mb-2">@complaint.Title</h2>
                        <p class="post-content text-secondary mb-1">@complaint.Content</p>
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <small class="text-muted meta-line">por @complaint.AuthorName • @complaint.CreatedAt.LocalDateTime.ToString("dd/MM/yyyy HH:mm")</small>
                            @if (complaint.HasProfanity)
                            {
                                <span class="badge text-bg-warning">Conteúdo censurado</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </article>
    }
}
