@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var antiForgeryToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var isFeedActive = string.Equals(currentController, "Home", System.StringComparison.OrdinalIgnoreCase)
        && string.Equals(currentAction, "Index", System.StringComparison.OrdinalIgnoreCase);
    var isCreatePostActive = string.Equals(currentController, "Posts", System.StringComparison.OrdinalIgnoreCase)
        && string.Equals(currentAction, "Create", System.StringComparison.OrdinalIgnoreCase);
    var isComplaintsActive = string.Equals(currentController, "Complaints", System.StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="csrf-token" content="@antiForgeryToken" />
    <title>@ViewData["Title"] - E-PANEL</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="app-body">
    <nav class="navbar navbar-expand-lg navbar-light app-navbar border-bottom sticky-top">
        <div class="container app-container py-2">
            <a class="navbar-brand app-brand d-inline-flex align-items-center me-3" asp-controller="Home" asp-action="Index">
                <span class="brand-logo-frame" aria-hidden="true">
                    <img class="brand-logo" src="~/css/img/f1d73635-b311-44fe-b125-12a46b60238c-removebg-preview.png" alt="E-PANEL" />
                </span>
            </a>
            <button class="navbar-toggler app-navbar-toggler px-2 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Alternar navegação">
                <span class="navbar-toggler-icon app-toggler-icon"></span>
            </button>
            <div id="mainNav" class="collapse navbar-collapse app-nav-collapse">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 nav-menu">
                        <li class="nav-item">
                            <a class="nav-link @(isFeedActive ? "is-active" : string.Empty)" asp-controller="Home" asp-action="Index" aria-current="@(isFeedActive ? "page" : null)">Feed</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(isCreatePostActive ? "is-active" : string.Empty)" asp-controller="Posts" asp-action="Create" aria-current="@(isCreatePostActive ? "page" : null)">Nova postagem</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(isComplaintsActive ? "is-active" : string.Empty)" asp-controller="Complaints" asp-action="Index" aria-current="@(isComplaintsActive ? "page" : null)">Reclamações</a>
                        </li>
                    </ul>
                    <form class="d-flex top-actions nav-cta" asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-primary btn-sm px-3 nav-logout-btn" type="submit">Sair</button>
                    </form>
                }
                else
                {
                    <div class="ms-auto d-flex gap-2 top-actions nav-cta">
                        <a class="btn btn-outline-secondary btn-sm px-3" asp-controller="Account" asp-action="Login">Entrar</a>
                        <a class="btn btn-primary btn-sm px-3" asp-controller="Account" asp-action="Register">Criar conta</a>
                    </div>
                }
            </div>
        </div>
    </nav>

    <main class="container app-container app-main">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/votes.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
